#!/usr/bin/env bash
set -euo pipefail

SUPPORTED_AGENTS=(".codex" ".agents" ".claude")

usage() {
  cat <<'EOF'
Usage: bin/install [project-root] [--agent .codex|.agents|.claude] [--yes]

Installs the clean-code skill collection into a project's agent skills folder.
Only .codex, .agents, and .claude are supported.

Examples:
  bin/install ~/Workspace/my-project
  bin/install ~/Workspace/my-project --agent .codex
  bin/install . --agent .agents --yes
EOF
}

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

is_supported_agent() {
  local agent="$1"
  local supported
  for supported in "${SUPPORTED_AGENTS[@]}"; do
    [[ "$agent" == "$supported" ]] && return 0
  done
  return 1
}

expand_path() {
  local path="$1"
  case "$path" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s/%s\n' "$HOME" "${path#"~/"}" ;;
    *) printf '%s\n' "$path" ;;
  esac
}

absolute_dir() {
  local path
  path="$(expand_path "$1")"
  [[ -d "$path" ]] || fail "Directory does not exist: $path"
  (cd "$path" && pwd -P)
}

prompt_project_root() {
  local input
  printf 'Project directory [%s]: ' "$PWD" >&2
  read -r input
  [[ -n "$input" ]] || input="$PWD"
  absolute_dir "$input"
}

confirm_project_root() {
  local project_root="$1"
  local answer
  printf 'Install clean-code skills into project: %s\n' "$project_root" >&2
  printf 'Continue? [y/N]: ' >&2
  read -r answer
  case "$answer" in
    y|Y|yes|YES) ;;
    *) printf 'Aborted.\n' >&2; exit 0 ;;
  esac
}

detect_agent_dirs() {
  local project_root="$1"
  local agent
  for agent in "${SUPPORTED_AGENTS[@]}"; do
    [[ -d "$project_root/$agent" ]] && printf '%s\n' "$agent"
  done
}

select_agent_dir() {
  local project_root="$1"
  local requested_agent="$2"
  local assume_yes="$3"
  local detected=()
  local agent answer index

  if [[ -n "$requested_agent" ]]; then
    is_supported_agent "$requested_agent" || fail "Unsupported agent directory: $requested_agent"
    mkdir -p "$project_root/$requested_agent"
    printf '%s\n' "$requested_agent"
    return
  fi

  while IFS= read -r agent; do
    detected+=("$agent")
  done < <(detect_agent_dirs "$project_root")

  if [[ "${#detected[@]}" -eq 1 ]]; then
    printf '%s\n' "${detected[0]}"
    return
  fi

  if [[ "${#detected[@]}" -gt 1 ]]; then
    if [[ "$assume_yes" == "1" ]]; then
      printf 'Found multiple agent directories:' >&2
      for agent in "${detected[@]}"; do
        printf ' %s' "$agent" >&2
      done
      printf '\nPass --agent .codex, --agent .agents, or --agent .claude.\n' >&2
      exit 1
    fi

    printf 'Found multiple agent directories:\n' >&2
    for index in "${!detected[@]}"; do
      printf '  %s) %s\n' "$((index + 1))" "${detected[$index]}" >&2
    done

    while true; do
      printf 'Choose one [1-%s]: ' "${#detected[@]}" >&2
      read -r answer
      if [[ "$answer" =~ ^[0-9]+$ ]] &&
        (( answer >= 1 && answer <= ${#detected[@]} )); then
        printf '%s\n' "${detected[$((answer - 1))]}"
        return
      fi
    done
  fi

  if [[ "$assume_yes" == "1" ]]; then
    mkdir -p "$project_root/.codex"
    printf '.codex\n'
    return
  fi

  printf 'No supported agent directory found in %s.\n' "$project_root" >&2
  printf 'Choose one to create:\n' >&2
  for index in "${!SUPPORTED_AGENTS[@]}"; do
    printf '  %s) %s\n' "$((index + 1))" "${SUPPORTED_AGENTS[$index]}" >&2
  done

  while true; do
    printf 'Choose one [1-%s]: ' "${#SUPPORTED_AGENTS[@]}" >&2
    read -r answer
    if [[ "$answer" =~ ^[0-9]+$ ]] &&
      (( answer >= 1 && answer <= ${#SUPPORTED_AGENTS[@]} )); then
      agent="${SUPPORTED_AGENTS[$((answer - 1))]}"
      mkdir -p "$project_root/$agent"
      printf '%s\n' "$agent"
      return
    fi
  done
}

install_skill() {
  local source_dir="$1"
  local skills_dir="$2"
  local name tmp_dir
  name="$(basename "$source_dir")"
  tmp_dir="$skills_dir/.tmp-$name-$$"

  rm -rf "$tmp_dir"
  cp -R "$source_dir" "$tmp_dir"
  rm -rf "$skills_dir/$name"
  mv "$tmp_dir" "$skills_dir/$name"
  printf 'Installed %s\n' "$name"
}

install_collection() {
  local repo_root="$1"
  local skills_dir="$2"
  local source_dir

  mkdir -p "$skills_dir"

  install_skill "$repo_root/skills/clean-code" "$skills_dir"

  for source_dir in "$repo_root"/skills/typescript/* "$repo_root"/skills/react/* "$repo_root"/skills/css/*; do
    [[ -d "$source_dir" ]] || continue
    install_skill "$source_dir" "$skills_dir"
  done
}

main() {
  local script_dir repo_root project_arg="" requested_agent="" assume_yes=0
  local project_root agent_dir skills_dir arg

  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  repo_root="$(cd "$script_dir/.." && pwd -P)"

  while [[ "$#" -gt 0 ]]; do
    arg="$1"
    case "$arg" in
      --agent)
        [[ "$#" -ge 2 ]] || fail "--agent requires a value"
        requested_agent="$2"
        shift 2
        ;;
      --yes|-y)
        assume_yes=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --*)
        fail "Unknown option: $arg"
        ;;
      *)
        [[ -z "$project_arg" ]] || fail "Only one project directory may be provided"
        project_arg="$arg"
        shift
        ;;
    esac
  done

  if [[ -n "$project_arg" ]]; then
    project_root="$(absolute_dir "$project_arg")"
  else
    project_root="$(prompt_project_root)"
  fi

  if [[ "$assume_yes" != "1" ]]; then
    confirm_project_root "$project_root"
  fi

  agent_dir="$(select_agent_dir "$project_root" "$requested_agent" "$assume_yes")"
  skills_dir="$project_root/$agent_dir/skills"

  printf 'Installing into %s\n' "$skills_dir"
  install_collection "$repo_root" "$skills_dir"
  printf 'Done. Restart your agent to pick up new skills.\n'
}

main "$@"
